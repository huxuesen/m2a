# MiMoCode2API Environment Configuration
# Copy this file to .env before running docker compose.

# === Authentication ===
API_KEY=your-api-key-here
MIMOCODE_SERVER_PASSWORD=your-server-password-here

# === Tool Calling Strategy ===
# MiMo models (mimo-auto, etc.) don't reliably follow prompt-injected <function_calls>
# format for tool calling. Instead, we disable the proxy's tool bridge and let
# Hermes Agent manage tool calling through its own system prompt mechanism.
#
# Key config:
#   DISABLE_TOOLS=true   — proxy doesn't inject tool prompts or bridge external tools
#   OMIT_SYSTEM_PROMPT=false — preserves Hermes's system prompt (contains tool definitions)
#   PROMPT_MODE=standard — standard mode, no special prompt injection
MIMOCODE_DISABLE_TOOLS=true
MIMOCODE_PROXY_OMIT_SYSTEM_PROMPT=false
MIMOCODE_PROXY_PROMPT_MODE=standard

# === Cleanup ===
MIMOCODE_PROXY_AUTO_CLEANUP_CONVERSATIONS=true
MIMOCODE_PROXY_CLEANUP_INTERVAL_MS=43200000
MIMOCODE_PROXY_CLEANUP_MAX_AGE_MS=86400000

# === Optional Overrides ===
# MIMOCODE_PROXY_PORT=10000
# MIMOCODE_SERVER_PORT=10001
# MIMOCODE_USE_ISOLATED_HOME=false
# MIMOCODE_PROXY_REQUEST_TIMEOUT_MS=180000
# MIMOCODE_PROXY_DEBUG=false